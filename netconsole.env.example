# Copy to /etc/crashwatch/netconsole.env and fill in your own values -- the
# ones below are documentation-range placeholders (RFC 5737 / RFC 7042), not
# real addresses.
#
# Get NETCONSOLE_LOCAL_IP / NETCONSOLE_LOCAL_DEV via: ip -4 addr show
# Get NETCONSOLE_REMOTE_MAC via: ping -c1 <remote-ip> && ip neigh show <remote-ip>
NETCONSOLE_LOCAL_PORT=6665
NETCONSOLE_LOCAL_IP=203.0.113.10
NETCONSOLE_LOCAL_DEV=eth0
NETCONSOLE_REMOTE_PORT=6666
NETCONSOLE_REMOTE_IP=203.0.113.20
NETCONSOLE_REMOTE_MAC=00:00:5e:00:53:01
